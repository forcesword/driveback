/*
 * DriveBack - USB Backup Plugin for Unraid
 * Main UI page (driveback.page)
 */

$JOBS_DIR  = "/boot/config/plugins/driveback/jobs";
$LOG_DIR   = "/var/log/driveback";

// ── Load all jobs ─────────────────────────────────────────────────────────────
function load_jobs($dir) {
  $jobs = [];
  if (!is_dir($dir)) return $jobs;
  foreach (glob("$dir/*.conf") as $f) {
    $id   = basename($f, '.conf');
    $data = parse_ini_file($f);
    if ($data !== false) {
      $data['id'] = $id;
      $jobs[$id]  = $data;
    }
  }
  return $jobs;
}

// ── Detect mounted USB drives ─────────────────────────────────────────────────
function get_usb_drives() {
  $drives = [];
  $mounts = file('/proc/mounts', FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
  foreach ($mounts as $line) {
    $parts = preg_split('/\s+/', $line);
    $dev   = $parts[0] ?? '';
    $mp    = $parts[1] ?? '';
    // /mnt/disks/ is where Unraid mounts unassigned devices (USB drives)
    if (strpos($mp, '/mnt/disks/') === 0) {
      $name = basename($mp);
      $drives[$mp] = $name;
    }
  }
  return $drives;
}

// ── Detect user shares ────────────────────────────────────────────────────────
function get_shares() {
  $shares = [];
  $dir = '/mnt/user';
  if (is_dir($dir)) {
    foreach (scandir($dir) as $entry) {
      if ($entry === '.' || $entry === '..') continue;
      if (is_dir("$dir/$entry")) $shares[] = $entry;
    }
  }
  return $shares;
}

$jobs   = load_jobs($JOBS_DIR);
$drives = get_usb_drives();
$shares = get_shares();
