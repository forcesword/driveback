<script>
const JOBS = <?= json_encode($jobs, JSON_PRETTY_PRINT) ?>;

// ── Modal helpers ──────────────────────────────────────────────────────────────
function openModal(id) {
  document.getElementById('edit-id').value = id || '';
  document.getElementById('modal-title').textContent = id ? 'Edit Backup Job' : 'New Backup Job';
  if (id && JOBS[id]) {
    const j = JOBS[id];
    document.getElementById('f-name').value    = j.JOB_NAME || '';
    document.getElementById('f-enabled').value = j.ENABLED  || 'yes';
    setSelectOrCustom('f-source', 'source-custom-wrap', 'f-source-custom', j.SOURCE || '');
    setSelectOrCustom('f-dest',   'dest-custom-wrap',   'f-dest-custom',   j.DEST   || '');
    const parts = (j.SCHEDULE || '0 2 * * *').split(' ');
    const hh = parts[1]?.padStart(2,'0') || '02';
    const mm = parts[0]?.padStart(2,'0') || '00';
    document.getElementById('f-time').value = `${hh}:${mm}`;
  } else {
    document.getElementById('f-name').value    = '';
    document.getElementById('f-source').value  = '';
    document.getElementById('f-dest').value    = '';
    document.getElementById('f-time').value    = '02:00';
    document.getElementById('f-enabled').value = 'yes';
    document.getElementById('source-custom-wrap').style.display = 'none';
    document.getElementById('dest-custom-wrap').style.display   = 'none';
  }
  document.getElementById('job-modal').classList.add('open');
}

function setSelectOrCustom(selId, wrapId, inputId, value) {
  const sel = document.getElementById(selId);
  let found = false;
  for (const opt of sel.options) {
    if (opt.value === value) { sel.value = value; found = true; break; }
  }
  if (!found && value) {
    sel.value = '__custom';
    document.getElementById(wrapId).style.display  = '';
    document.getElementById(inputId).value         = value;
  }
}

function closeModal() {
  document.getElementById('job-modal').classList.remove('open');
}

document.getElementById('f-source').addEventListener('change', function() {
  document.getElementById('source-custom-wrap').style.display = this.value === '__custom' ? '' : 'none';
});
document.getElementById('f-dest').addEventListener('change', function() {
  document.getElementById('dest-custom-wrap').style.display = this.value === '__custom' ? '' : 'none';
});

// ── Save job ───────────────────────────────────────────────────────────────────
function saveJob() {
  const id      = document.getElementById('edit-id').value;
  const name    = document.getElementById('f-name').value.trim();
  const srcSel  = document.getElementById('f-source').value;
  const dstSel  = document.getElementById('f-dest').value;
  const source  = srcSel === '__custom' ? document.getElementById('f-source-custom').value.trim() : srcSel;
  const dest    = dstSel === '__custom' ? document.getElementById('f-dest-custom').value.trim()   : dstSel;
  const time    = document.getElementById('f-time').value;
  const enabled = document.getElementById('f-enabled').value;

  if (!name)   { alert('Job name is required.');          return; }
  if (!source) { alert('Source path is required.');       return; }
  if (!dest)   { alert('Destination path is required.');  return; }

  const [hh, mm] = time.split(':');
  const schedule = `${parseInt(mm)} ${parseInt(hh)} * * *`;

  fetch('plugins/driveback/include/jobs.php', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action:'save', id, JOB_NAME:name, SOURCE:source, DEST:dest, SCHEDULE:schedule, ENABLED:enabled })
  })
  .then(r => r.json())
  .then(d => {
    if (d.ok) { closeModal(); location.reload(); }
    else       alert('Error: ' + d.error);
  })
  .catch(() => alert('Request failed.'));
}

// ── Run job ────────────────────────────────────────────────────────────────────
function runJob(id) {
  if (!confirm('Run backup job now?')) return;
  fetch('plugins/driveback/include/exec.php', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action:'run', id })
  })
  .then(r => r.json())
  .then(d => {
    if (d.ok) alert('Job started. Check the log for progress.');
    else       alert('Error: ' + d.error);
  });
}

// ── Toggle enabled ─────────────────────────────────────────────────────────────
function toggleJob(id, enabled) {
  fetch('plugins/driveback/include/jobs.php', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action:'toggle', id, enabled: enabled ? 'yes' : 'no' })
  })
  .then(r => r.json())
  .then(d => { if (!d.ok) alert('Error: ' + d.error); });
}

// ── Delete job ─────────────────────────────────────────────────────────────────
function deleteJob(id) {
  if (!confirm('Delete this backup job?')) return;
  fetch('plugins/driveback/include/jobs.php', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action:'delete', id })
  })
  .then(r => r.json())
  .then(d => {
    if (d.ok) document.getElementById('job-card-' + id).remove();
    else       alert('Error: ' + d.error);
  });
}

// ── View log ───────────────────────────────────────────────────────────────────
function viewLog(id) {
  document.getElementById('log-title').textContent   = 'Log: ' + (JOBS[id]?.JOB_NAME || id);
  document.getElementById('log-content').textContent = 'Loading…';
  document.getElementById('log-modal').classList.add('open');

  fetch('plugins/driveback/include/jobs.php?action=log&id=' + encodeURIComponent(id))
  .then(r => r.json())
  .then(d => {
    document.getElementById('log-content').textContent = d.log || '(no log yet)';
  });
}

function closeLogModal() {
  document.getElementById('log-modal').classList.remove('open');
}

// Close modals on overlay click
['job-modal','log-modal'].forEach(id => {
  document.getElementById(id).addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('open');
  });
});
</script>
